{
  "name": "copilot-worktrees",
  "displayName": "Copilot Worktrees",
  "description": "Manage git worktrees and launch GitHub Copilot CLI in them — sidebar panel with one-click worktree switching and Copilot terminal in the editor area.",
  "version": "0.1.0",
  "publisher": "vivazqu",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "worktree",
    "copilot",
    "copilot-cli",
    "terminal",
    "branch"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nickvazz/copilot-worktrees-vscode"
  },
  "icon": "media/icon.png",
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-worktrees",
          "title": "Copilot Worktrees",
          "icon": "media/worktree.svg"
        }
      ]
    },
    "views": {
      "copilot-worktrees": [
        {
          "id": "copilotWorktrees",
          "name": "Worktrees",
          "icon": "media/worktree.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotWorktrees.refresh",
        "title": "Refresh Worktrees",
        "category": "Copilot Worktrees",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotWorktrees.openInNewWindow",
        "title": "Open in New Window",
        "category": "Copilot Worktrees",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "copilotWorktrees.launchCopilot",
        "title": "Launch Copilot CLI",
        "category": "Copilot Worktrees",
        "icon": "$(terminal)"
      },
      {
        "command": "copilotWorktrees.openAndLaunchCopilot",
        "title": "Open in New Window + Launch Copilot",
        "category": "Copilot Worktrees",
        "icon": "$(rocket)"
      },
      {
        "command": "copilotWorktrees.createWorktree",
        "title": "Create Worktree",
        "category": "Copilot Worktrees",
        "icon": "$(add)"
      },
      {
        "command": "copilotWorktrees.removeWorktree",
        "title": "Remove Worktree",
        "category": "Copilot Worktrees",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "copilotWorktrees.createWorktree",
          "when": "view == copilotWorktrees",
          "group": "navigation@1"
        },
        {
          "command": "copilotWorktrees.refresh",
          "when": "view == copilotWorktrees",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "copilotWorktrees.openAndLaunchCopilot",
          "when": "view == copilotWorktrees && viewItem == worktree",
          "group": "inline@1"
        },
        {
          "command": "copilotWorktrees.openInNewWindow",
          "when": "view == copilotWorktrees && viewItem == worktree",
          "group": "inline@2"
        },
        {
          "command": "copilotWorktrees.launchCopilot",
          "when": "view == copilotWorktrees && viewItem == worktree",
          "group": "1_actions@1"
        },
        {
          "command": "copilotWorktrees.openInNewWindow",
          "when": "view == copilotWorktrees && viewItem == worktree",
          "group": "1_actions@2"
        },
        {
          "command": "copilotWorktrees.openAndLaunchCopilot",
          "when": "view == copilotWorktrees && viewItem == worktree",
          "group": "1_actions@3"
        },
        {
          "command": "copilotWorktrees.removeWorktree",
          "when": "view == copilotWorktrees && viewItem == worktree && !copilotWorktrees.isCurrent",
          "group": "2_danger@1"
        }
      ]
    },
    "configuration": {
      "title": "Copilot Worktrees",
      "properties": {
        "copilotWorktrees.copilotCommand": {
          "type": "string",
          "default": "copilot",
          "description": "Command to launch GitHub Copilot CLI (e.g. 'copilot', 'gh copilot')."
        },
        "copilotWorktrees.terminalLocation": {
          "type": "string",
          "enum": [
            "editor",
            "panel"
          ],
          "default": "editor",
          "description": "Where to open the Copilot terminal: 'editor' (as a tab) or 'panel' (bottom)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
